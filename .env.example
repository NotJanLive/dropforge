# Server
PORT=4700
NODE_ENV=production

# Dropforge Auth (Admin/User Login)
# Generate strong random values — do not commit real secrets.
SESSION_SECRET=change-me-generate-a-long-random-string
ENCRYPTION_KEY=change-me-64-character-hex-encryption-key-for-twitch-tokens

# Optional — matches reference miner default (WEB | MOBILE_WEB | ANDROID_APP | SMARTBOX)
TWITCH_CLIENT_TYPE=ANDROID_APP
